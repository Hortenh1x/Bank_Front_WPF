<Page x:Class="BankFrontEnd.AddAccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddAccountPage">
    <Grid>
        <Border Style="{StaticResource CardStyle}" MaxWidth="720" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Create New Account" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="A new account will be created for your current user."
                           Margin="0,8,0,8"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock x:Name="StatusText" Margin="0,0,0,16" Foreground="{StaticResource TextMutedBrush}"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Create Account"
                            Width="150"
                            Height="38"
                            Margin="0,0,10,0"
                            Style="{StaticResource SuccessButtonStyle}"
                            Click="CreateAccount_Click"/>
                    <Button Content="View My Accounts"
                            Width="160"
                            Height="38"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="Back_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
