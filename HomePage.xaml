<Page x:Class="BankFrontEnd.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0"/>
                <GradientStop Color="#EEF4F7" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Style="{StaticResource CardStyle}"
                MaxWidth="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="24">
            <StackPanel>
                <TextBlock Text="Banking, simplified." Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Manage accounts, transfer funds, and use ATM operations from one clean workspace."
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0,8,0,20"
                           TextWrapping="Wrap"/>

                <Border Height="1" Background="{StaticResource BorderBrushColor}" Margin="0,0,0,18"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Secure access with JWT sessions"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,24,0"/>
                    <TextBlock Text="Real-time account actions"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
