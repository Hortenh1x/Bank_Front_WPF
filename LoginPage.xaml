<Page x:Class="BankFrontEnd.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage">

    <Grid>
        <Border Style="{StaticResource CardStyle}"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Login" Style="{StaticResource PageTitleStyle}" HorizontalAlignment="Center"/>
                <TextBlock Text="Access your account dashboard"
                           Style="{StaticResource PageSubtitleStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,24"/>

                <TextBlock Text="User ID" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="UserIdTextBox" Margin="0,0,0,14"/>

                <TextBlock Text="Password" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="UserPasswordBox" Margin="0,0,0,20"/>

                <Button Content="Login"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40"
                        Click="LoginButton_Click"/>

                <Button Content="Create account"
                        Style="{StaticResource LinkButtonStyle}"
                        HorizontalAlignment="Center"
                        Margin="0,14,0,0"
                        Click="RegisterButton_Click"/>

                <TextBlock x:Name="ErrorMessageText"
                           Foreground="#DC2626"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
