<Page x:Class="BankFrontEnd.PaymentConfirmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PaymentConfirmPage">

    <Grid>
        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,22">
                    <TextBlock Text="Confirm payment" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Review a shop payment and approve it from one of your bank accounts."
                               Style="{StaticResource PageSubtitleStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="External payment ID" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="ExternalPaymentIdTextBox"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Load payment"
                            Width="140"
                            Height="38"
                            Margin="14,22,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="LoadPayment_Click"/>
                </Grid>

                <Border Grid.Row="2"
                        x:Name="PaymentDetailsPanel"
                        BorderBrush="{StaticResource BorderBrushColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18"
                        Margin="0,0,0,18"
                        Background="#F8FAFC"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,18,12">
                            <TextBlock Text="Merchant" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock x:Name="MerchantText" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="Amount" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock x:Name="AmountText" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,18,12">
                            <TextBlock Text="Status" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock x:Name="PaymentStatusText" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="Expires at" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock x:Name="ExpiresAtText" FontSize="16"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                            <TextBlock Text="Shop order" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock x:Name="ShopOrderText" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="3" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Pay from account" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="AccountsComboBox"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="AccountsComboBox_SelectionChanged"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="ConfirmPaymentButton"
                            Content="Confirm payment"
                            Width="160"
                            Height="38"
                            Margin="14,22,0,0"
                            Style="{StaticResource SuccessButtonStyle}"
                            IsEnabled="False"
                            Click="ConfirmPayment_Click"/>
                </Grid>

                <TextBlock Grid.Row="4"
                           x:Name="StatusText"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Page>
