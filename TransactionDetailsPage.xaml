<Page x:Class="BankFrontEnd.TransactionDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="TransactionDetailsPage">

    <Grid>
        <Border Style="{StaticResource CardStyle}" MaxWidth="760" HorizontalAlignment="Center">
            <StackPanel>
                <Button Content="Back"
                        Width="92"
                        Height="34"
                        HorizontalAlignment="Left"
                        Style="{StaticResource GhostButtonStyle}"
                        Click="Back_Click"/>

                <TextBlock Text="Transaction Details" Style="{StaticResource PageTitleStyle}" Margin="0,12,0,2"/>
                <TextBlock Text="Detailed view of a single transaction" Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,18"/>

                <Border x:Name="TypeBadge" Padding="10,4" CornerRadius="12" HorizontalAlignment="Left" Margin="0,0,0,16">
                    <TextBlock x:Name="TypeText" FontSize="12" FontWeight="SemiBold"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Transaction ID" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="TransactionIdText" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" FontWeight="SemiBold"/>

                    <TextBlock Text="Date and Time" Grid.Row="1" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="DateText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Text="Amount" Grid.Row="2" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="AmountText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" FontWeight="SemiBold"/>

                    <TextBlock Text="From Account" Grid.Row="3" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="FromText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Text="From Owner" Grid.Row="4" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="FromOwnerText" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Text="To Account" Grid.Row="5" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="ToText" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Text="To Owner" Grid.Row="6" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="ToOwnerText" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Text="Type" Grid.Row="7" Grid.Column="0" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="TypeValueText" Grid.Row="7" Grid.Column="1" Margin="0,0,0,10"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
